# Shared develop environment values (non-secret defaults)
# Personal/team overrides: .env.dev.local

PUBLIC_TILE_SERVER_BASE_URL=https://dev.allmaps.xyz
PUBLIC_TILE_VIEWER_BASE_URL=https://dev.tiles.allmaps.org
PUBLIC_PREVIEW_BASE_URL=https://dev.preview.allmaps.org
PUBLIC_VIEWER_BASE_URL=https://dev.viewer.allmaps.org
PUBLIC_ANNOTATIONS_BASE_URL=https://dev.annotations.allmaps.org
PUBLIC_LIVE_BASE_URL=https://dev.live.allmaps.org
PUBLIC_REST_BASE_URL=https://dev.api.allmaps.org
PUBLIC_BETTER_AUTH_URL=https://dev.api.allmaps.org
PUBLIC_EXAMPLES_API_URL=https://sammeltassen-allmaps.web.val.run

PUBLIC_STATS_WEBSITE_ID=
PUBLIC_GEOCODE_EARTH_KEY=

PUBLIC_BANNER_ENABLED=true
PUBLIC_BANNER_TEXT=This is the development version!

NODE_VERSION=24
SECURE=true

DATABASE_URL=
DIRECT_DATABASE_URL=
LOG_QUERIES=false

BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

USE_CACHE=true
BROWSER_CACHE_HOURS=1
CLOUDFLARE_CACHE_HOURS=1
