# Shared production environment values (non-secret defaults)
# Team-specific overrides: .env.production.local

PUBLIC_TILE_SERVER_BASE_URL=https://allmaps.xyz
PUBLIC_TILE_VIEWER_BASE_URL=https://tiles.allmaps.org
PUBLIC_PREVIEW_BASE_URL=https://preview.allmaps.org
PUBLIC_VIEWER_BASE_URL=https://viewer.allmaps.org
PUBLIC_ANNOTATIONS_BASE_URL=https://annotations.allmaps.org
PUBLIC_LIVE_BASE_URL=https://live.allmaps.org
PUBLIC_REST_BASE_URL=https://api.allmaps.org
PUBLIC_EXAMPLES_API_URL=https://sammeltassen-allmaps.web.val.run

PUBLIC_STATS_WEBSITE_ID=
PUBLIC_GEOCODE_EARTH_KEY=

PUBLIC_BANNER_ENABLED=false
PUBLIC_BANNER_TEXT=

NODE_VERSION=24

DATABASE_URL=
DIRECT_DATABASE_URL=
LOG_QUERIES=false

BETTER_AUTH_URL=https://api.allmaps.org
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

USE_CACHE=true
BROWSER_CACHE_HOURS=720
CLOUDFLARE_CACHE_HOURS=24
