{
  "name": "@allmaps/api-live",
  "version": "3.0.0",
  "private": "true",
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "PORT=$(../../port.js live) bun --no-env-file --env-file=../../.env.localhost --env-file=../../.env.localhost.local --watch src/index.ts",
    "types": "tsc --noEmit",
    "build": "tsc",
    "lerna-build": "lerna run build --scope @allmaps/api-live --include-dependencies",
    "lint": "prettier --ignore-path ../../.gitignore --check src && eslint src --ext .js,.ts",
    "start": "PORT=$(../../port.js live) bun --no-env-file --env-file=../../.env.production --env-file=../../.env.production.local dist/src/index.js"
  },
  "dependencies": {
    "@allmaps/annotation": "workspace:^",
    "@allmaps/api-shared": "workspace:^",
    "@allmaps/db": "workspace:^",
    "@allmaps/id": "workspace:^",
    "@allmaps/stdlib": "workspace:^",
    "@allmaps/transform": "workspace:^",
    "@allmaps/project": "workspace:^",
    "@allmaps/env": "workspace:^",
    "@teamwork/websocket-json-stream": "^2.0.0",
    "cors": "^2.8.5",
    "diff-match-patch": "^1.0.5",
    "drizzle-orm": "catalog:",
    "express": "^5.1",
    "json0-ot-diff": "^1.1.2",
    "lodash-es": "^4.17.21",
    "ot-json1": "^1.0.1",
    "postgres": "catalog:",
    "ramda": "^0.29.0",
    "sharedb": "^5.2.2",
    "ws": "^8.13.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/diff-match-patch": "^1.0.32",
    "@types/express": "^5.0.2",
    "@types/geojson": "^7946.0.14",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "@types/ramda": "^0.29.3",
    "@types/sharedb": "^3.3.12",
    "@types/ws": "^8.5.5",
    "typescript": "catalog:"
  }
}
