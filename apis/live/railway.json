{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm turbo run build --filter=@allmaps/api-live..."
  },
  "deploy": {
    "startCommand": "node apis/live/dist/src/index.js",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
