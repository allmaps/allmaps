{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "here",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2025-01-01",
  "assets": { "directory": ".svelte-kit/cloudflare", "binding": "ASSETS" },
  "observability": {
    "logs": {
      "enabled": false
    }
  },
  "env": {
    "dev": {
      "name": "here-develop"
    }
  }
}
