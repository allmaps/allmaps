{
  "name": "@allmaps/viewer",
  "version": "1.0.0-beta.87",
  "private": true,
  "author": {
    "name": "Bert Spaan",
    "email": "hello@bertspaan.nl",
    "url": "https://bertspaan.nl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/allmaps/allmaps.git",
    "directory": "apps/viewer"
  },
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=32768' vite dev --mode localhost",
    "build": "vite build",
    "lerna-build": "lerna run build --scope @allmaps/viewer --include-dependencies",
    "deploy": "node ../../scripts/wrangler-deploy.ts --cwd . --dotenv-file ../../.env.production --dotenv-file ../../.env.production.local",
    "deploy:dev": "node ../../scripts/wrangler-deploy.ts --cwd . --wrangler-env dev --dotenv-file ../../.env.dev --dotenv-file ../../.env.dev.local",
    "tail": "wrangler tail",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "types": "tsc --noEmit",
    "lint": "prettier --ignore-path ../../.gitignore --check . && eslint .",
    "format": "prettier --ignore-path ../../.gitignore --write ."
  },
  "dependencies": {
    "@allmaps/annotation": "workspace:^",
    "@allmaps/id": "workspace:^",
    "@allmaps/ui": "workspace:^",
    "@allmaps/basemap": "workspace:^",
    "@allmaps/bearing": "workspace:^",
    "@allmaps/tailwind": "workspace:^",
    "@allmaps/iiif-parser": "workspace:^",
    "@allmaps/maplibre": "workspace:^",
    "@allmaps/project": "workspace:^",
    "@allmaps/render": "workspace:^",
    "@allmaps/stdlib": "workspace:^",
    "@allmaps/components": "workspace:^",
    "@allmaps/env": "workspace:^",
    "bits-ui": "catalog:",
    "maplibre-gl": "catalog:"
  },
  "devDependencies": {
    "@allmaps/types": "workspace:^",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.39.1",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^22",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.49.0",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.17",
    "typescript": "catalog:",
    "typescript-eslint": "^8.48.1",
    "vite": "catalog:",
    "vite-plugin-devtools-json": "^1.0.0",
    "phosphor-svelte": "^3.0.1",
    "wrangler": "^4.3.0"
  }
}
