{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "viewer",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2026-02-18",
  "compatibility_flags": ["nodejs_compat"],
  "assets": { "directory": ".svelte-kit/cloudflare", "binding": "ASSETS" },
  "observability": {
    "logs": {
      "enabled": false
    }
  },
  "env": {
    "dev": {
      "name": "viewer-develop"
    }
  }
}
