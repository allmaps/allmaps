{
  "name": "@allmaps/env",
  "version": "1.0.0-beta.0",
  "private": true,
  "description": "Shared environment schemas for Allmaps workspaces",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./rest": "./dist/rest.js",
    "./annotations": "./dist/annotations.js",
    "./live": "./dist/live.js",
    "./viewer": "./dist/viewer.js",
    "./latest": "./dist/latest.js",
    "./here": "./dist/here.js",
    "./editor": "./dist/editor.js",
    "./admin": "./dist/admin.js",
    "./tileserver": "./dist/tileserver.js",
    "./preview": "./dist/preview.js",
    "./worker": "./dist/worker.js",
    "./app": "./dist/app.js",
    "./better-auth": "./dist/better-auth.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/allmaps/allmaps.git",
    "directory": "packages/env"
  },
  "scripts": {
    "watch": "tsc --watch",
    "build": "tsc --noCheck",
    "types": "tsc --noEmit",
    "lint": "prettier --ignore-path ../../.gitignore --check src && eslint src --ext .js,.ts",
    "format": "prettier --ignore-path ../../.gitignore --write src"
  },
  "license": "MIT",
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.6.2"
  }
}
