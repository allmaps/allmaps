{
  "name": "@allmaps/tileserver",
  "version": "1.0.0-beta.79",
  "description": "Allmaps Tile Server",
  "private": true,
  "author": {
    "name": "Bert Spaan",
    "email": "hello@bertspaan.nl",
    "url": "https://bertspaan.nl"
  },
  "main": "./src/index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/allmaps/allmaps.git",
    "directory": "workers/tileserver"
  },
  "scripts": {
    "lerna-build": "lerna run build --scope @allmaps/tileserver --include-dependencies",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "dev": "wrangler dev --port $(../../port.js tileserver) --env dev",
    "lint": "prettier --check src test scripts && eslint src test scripts --ext .js,.ts",
    "lerna-build": "lerna run build --scope @allmaps/tileserver --include-dependencies",
    "types": "tsc --noEmit",
    "format": "prettier --write src test scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx scripts/benchmark.ts",
    "compare": "tsx scripts/compare-outputs.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@allmaps/annotation": "workspace:^",
    "@allmaps/id": "workspace:^",
    "@allmaps/iiif-parser": "workspace:^",
    "@allmaps/project": "workspace:^",
    "@allmaps/render": "workspace:^",
    "@allmaps/render-wasm": "workspace:^",
    "@allmaps/stdlib": "workspace:^",
    "@allmaps/transform": "workspace:^",
    "@allmaps/types": "workspace:^",
    "@cloudflare/kv-asset-handler": "^0.3.1",
    "@cloudflare/workers-types": "^4.20240320.1",
    "@types/eslint": "^8.56.0",
    "@types/node": "catalog:",
    "@types/pixelmatch": "^5.2.6",
    "@types/upng-js": "^2.1.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "itty-router": "^5.0.16",
    "jpeg-js": "^0.4.4",
    "pixelmatch": "^5.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "upng-js": "^2.1.0",
    "vitest": "catalog:",
    "wrangler": "^4.0.0"
  }
}
